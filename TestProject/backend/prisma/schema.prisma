
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
}

model User {
  id        Int      @id @default(autoincrement())
  username      String
  phonenumber     String   @unique
  dutyLogs  DutyLog[]
}

model Info {
  id        Int      @id @default(autoincrement())
  description String
}

model Position {
  id        Int      @id @default(autoincrement())
  title     String
}

model Source {
  id        Int      @id @default(autoincrement())
  name      String
}

model ShiftItem {
  id        Int      @id @default(autoincrement())
  shiftDate DateTime
}

model DutyLog {
  id        Int      @id @default(autoincrement())
  logDate   DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}